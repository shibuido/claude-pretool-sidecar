# QA environment WITH Claude Code CLI for live hook integration tests.
#
# This image extends the standalone QA environment by adding Node.js
# and the Claude Code CLI, enabling tests that exercise the sidecar
# as a real Claude Code PreToolUse/PostToolUse hook.
#
# Authentication: pass ANTHROPIC_API_KEY at runtime:
#   docker run -e ANTHROPIC_API_KEY="sk-ant-..." cpts-claude-code-image
#
# Multi-stage build:
#   Stage 1: Rust build (same as standalone)
#   Stage 2: Runtime with Claude Code CLI + QA suite

# --- Stage 1: Build (identical to standalone) ---
FROM rust:1.86-slim AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

COPY Cargo.toml Cargo.lock ./
RUN mkdir -p src/bin && \
    echo 'fn main() { println!("dummy"); }' > src/main.rs && \
    echo 'fn main() { println!("dummy"); }' > src/bin/logger.rs && \
    cargo build --release 2>/dev/null || true && \
    cargo build --release --tests 2>/dev/null || true

COPY src/ src/
COPY tests/ tests/
RUN touch src/main.rs src/bin/logger.rs && \
    cargo build --release && \
    cargo test --release --no-run

# --- Stage 2: Runtime with Claude Code ---
FROM debian:bookworm-slim AS qa-claude-code

LABEL maintainer="shibuido" \
      description="QA environment for claude-pretool-sidecar WITH Claude Code CLI" \
      org.opencontainers.image.source="https://github.com/shibuido/claude-pretool-sidecar"

# Layer 1: System deps + Node.js (most stable)
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    jq \
    coreutils \
    findutils \
    curl \
    ca-certificates \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22.x (LTS) via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Layer 2: Install Claude Code CLI (changes less often than our code)
RUN --mount=type=cache,target=/root/.npm \
    npm install -g @anthropic-ai/claude-code \
    && claude --version

WORKDIR /qa

# Layer 3: Copy built binaries
COPY --from=builder /build/target/release/claude-pretool-sidecar /usr/local/bin/
COPY --from=builder /build/target/release/claude-pretool-logger /usr/local/bin/

# Layer 4: Copy QA suite (changes most often — last layer for cache efficiency)
COPY qa/ /qa/
COPY tests/fixtures/ /qa/rust-test-fixtures/
COPY examples/ /qa/examples/

RUN chmod +x /qa/scripts/*.sh /qa/helpers/*.sh /qa/docker/*.sh 2>/dev/null || true

# Git init for Claude Code (it requires a git repo context)
RUN git init /qa-workspace && \
    cd /qa-workspace && \
    git config user.email "qa@test" && \
    git config user.name "QA" && \
    touch .gitkeep && git add . && git commit -m "init" --quiet

# Environment variables
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# ANTHROPIC_API_KEY must be provided at runtime

# Default: show help
ENTRYPOINT ["/bin/bash", "-c"]
CMD ["echo 'QA Environment with Claude Code CLI ready.' && echo '' && echo 'Usage:' && echo '  Run standalone tests:  /qa/scripts/run-all-standalone.sh --skip-cargo' && echo '  Run live CC tests:     /qa/scripts/run-all-live-claude-code.sh' && echo '  Interactive shell:     override entrypoint with bash' && echo '' && echo 'Claude Code version:' && claude --version && echo '' && echo 'Requires: -e ANTHROPIC_API_KEY=sk-ant-...'"]
