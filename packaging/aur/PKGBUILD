# Maintainer: shibuido <https://github.com/shibuido>
pkgname=claude-pretool-sidecar
pkgver=0.1.0
pkgrel=1
pkgdesc='A composable sidecar for Claude Code hooks that aggregates tool-approval votes from multiple providers'
arch=('x86_64' 'aarch64')
url='https://github.com/shibuido/claude-pretool-sidecar'
license=('MIT')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/shibuido/$pkgname/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release
}

check() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo test --frozen
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 target/release/claude-pretool-sidecar "$pkgdir/usr/bin/claude-pretool-sidecar"
    install -Dm755 target/release/claude-pretool-logger "$pkgdir/usr/bin/claude-pretool-logger"
    install -Dm755 target/release/claude-pretool-analyzer "$pkgdir/usr/bin/claude-pretool-analyzer"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
